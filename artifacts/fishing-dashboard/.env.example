# Copy these values into Replit Secrets or a local .env file.

# Optional but recommended for wiki entries, preferences, fishing logs, and
# chat tools that need persistent storage.
DATABASE_URL=postgresql://user:password@host:5432/database

# Required for AI chat through OpenRouter.
OPENROUTER_API_KEY=

# Optional. Without this, AQI endpoints return estimated guidance.
AIRNOW_API_KEY=
