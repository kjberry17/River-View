modules = ["nodejs-24", "python-3.11"]
entrypoint = "artifacts/fishing-dashboard/app.py"

[run]
args = ["bash", "-lc", "python -m pip install -r artifacts/fishing-dashboard/requirements.txt && exec bash artifacts/fishing-dashboard/start.sh"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["bash", "-lc", "python -m pip install -r artifacts/fishing-dashboard/requirements.txt"]
run = ["bash", "-lc", "exec bash artifacts/fishing-dashboard/start.sh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Oregon Fishing Dashboard"

[[workflows.workflow]]
name = "Oregon Fishing Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/fishing-dashboard && pip install -q flask flask-cors requests openai && PORT=5000 python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "rapidfuzz-cpp", "taskflow"]
