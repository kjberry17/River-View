modules = ["nodejs-24", "python-3.11"]
entrypoint = "artifacts/fishing-dashboard/app.py"

[run]
args = ["bash", "-lc", "python -m pip install -r artifacts/fishing-dashboard/requirements.txt && exec bash artifacts/fishing-dashboard/start.sh"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["bash", "-lc", "python -m pip install -r artifacts/fishing-dashboard/requirements.txt"]
run = ["bash", "-lc", "exec bash artifacts/fishing-dashboard/start.sh"]

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "rapidfuzz-cpp", "taskflow"]
